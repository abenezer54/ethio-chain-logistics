# PostgreSQL
POSTGRES_DB=ethio_chain
POSTGRES_USER=ethio_user
POSTGRES_PASSWORD=ethio_pass
POSTGRES_PORT=5432

# pgAdmin
PGADMIN_EMAIL=admin@local.dev
PGADMIN_PASSWORD=admin123
PGADMIN_PORT=5050

# API (backend/)
API_PORT=8080
GIN_MODE=debug
JWT_SECRET=dev-secret
ADMIN_EMAIL=admin@local.dev
ADMIN_PASSWORD=admin123
# Local Postgres URL (host machine → Docker published port)
DATABASE_URL=postgres://ethio_user:ethio_pass@localhost:5432/ethio_chain?sslmode=disable
# When running the API inside Docker, use host `postgres` instead of `localhost`.
# POSTGRES_HOST=localhost
